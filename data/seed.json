        {
            "category": "Quantitative Aptitude",
            "topic": "Percentages",
            "theory": "Percentage means 'per 100'. It is a fraction with denominator 100. It is denoted by symbol %.",
            "formulas": [
                "Percentage = (Value / Total Value) * 100",
                "x% of y = (x/100) * y"
            ],
            "examples": "Example 1: Find 20% of 150 = (20/100)*150 = 30."
        },
        {
            "category": "Quantitative Aptitude",
            "topic": "Profit and Loss",
            "theory": "Profit happens when Selling Price (SP) > Cost Price (CP). Loss happens when SP < CP.",
            "formulas": [
                "Profit = SP - CP",
                "Loss = CP - SP",
                "Profit % = (Profit/CP)*100",
                "Loss % = (Loss/CP)*100"
            ],
            "examples": "Example: CP = 100, SP = 120. Profit = 20. Profit % = (20/100)*100 = 20%."
        },
        {
            "category": "Quantitative Aptitude",
            "topic": "Time and Work",
            "theory": "Work done is directly proportional to time. If A can do a piece of work in n days, then A's 1 day's work = 1/n.",
            "formulas": [
                "Work = Rate \u00d7 Time",
                "If A does work in x days, and B in y days, A+B 1 day work = 1/x + 1/y"
            ],
            "examples": "If A takes 10 days and B takes 15 days, together they take 1/(1/10+1/15) = 6 days."
        }
    ],
